# Google Gemini API (GRATUITO)
# Obtener de: https://aistudio.google.com/app/apikeys
# Click en "Create API Key" y copia la key completa
# 
# IMPORTANTE: Crear 4 keys para distribuir la carga:
# - Agent 1 usará GOOGLE_GEMINI_API_KEY
# - Agent 2 usará GOOGLE_GEMINI_API_KEY_2
# - Agent 3 usará GOOGLE_GEMINI_API_KEY_3
# - Agent 4 usará GOOGLE_GEMINI_API_KEY_4
# Esto cuadruplica el límite diario de requests (6,000/día)
GOOGLE_GEMINI_API_KEY=AIzaSyD_xxxxxxxxxxxxxxxxxxxxx
GOOGLE_GEMINI_API_KEY_2=AIzaSyD_xxxxxxxxxxxxxxxxxxxxx
GOOGLE_GEMINI_API_KEY_3=AIzaSyD_xxxxxxxxxxxxxxxxxxxxx
GOOGLE_GEMINI_API_KEY_4=AIzaSyD_xxxxxxxxxxxxxxxxxxxxx

# Telegram Notifications (OPCIONAL - Gratis)
# Bot Token: Obtener creando bot con @BotFather en Telegram
# Chat ID: Obtener con @userinfobot en Telegram
# Descomenta estas líneas para activar notificaciones
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=123456789

# Google Drive (OPCIONAL - si quieres autoupload a Drive)
# ID de la carpeta padre donde se guardarán los reportes (Research-Reports)
# Descomenta si quieres usar esta funcionalidad
# GOOGLE_DRIVE_FOLDER_ID=1ABC123xyz

# Google Service Account (OPCIONAL - para Drive automation)
# Descargar desde: https://console.cloud.google.com/iam-admin/serviceaccounts
# Copiar el JSON completo aquí si lo necesitas
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"xxx"...}

# Opcional: para testing/debugging
DEBUG=false
